---
export const prerender = false;

import SectionHero from "../components/Section/SectionHero.astro";
import SectionWrapper from "../components/Section/SectionWrapper.astro";
import Layout from "../layouts/Layout.astro";
import ProjectList from "../components/Projects/ProjectList.svelte";

import { BackendAPI } from "../lib/api";

const projectsData = await BackendAPI.projects.getAll().catch(() => ({
  items: [],
  nextCursor: null,
  pageSize: 0,
}));
---

<Layout title="Projects">
  <SectionWrapper>
    <SectionHero
      eyebrow="List"
      title="Projects"
      description="List of all of my projects"
    />

    <ProjectList
      client:load
      projects={projectsData.items}
      nextCursor={projectsData.nextCursor}
    />
  </SectionWrapper>
</Layout>
