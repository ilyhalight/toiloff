---
import Project from "../components/Project/Project.astro";
import ProjectItem from "../components/Project/ProjectItem.astro";
import SectionHero from "../components/Section/SectionHero.astro";
import SectionWrapper from "../components/Section/SectionWrapper.astro";
import Layout from "../layouts/Layout.astro";
import { projects } from "../data/projects";
---

<Layout title="Projects">
  <SectionWrapper>
    <SectionHero
      eyebrow="labs"
      title="Projects"
      description="A compact index of my projects and experiments"
    />
    <Project>
      {projects.map((project) => <ProjectItem {...project} />)}
    </Project>
  </SectionWrapper>
</Layout>
