---
import { Image } from "astro:assets";

import Layout from "../layouts/Layout.astro";
import NotFoundImage from "../assets/errors/404.png";
---

<Layout title="404">
  <section class="error-section">
    <div class="error-image__wrapper">
      <Image
        class="error-image"
        src={NotFoundImage}
        alt="A kawaii-styled image with text '404 Not Found'"
      />
    </div>
    <a href="/" class="error-link button button_outline">Go Home</a>
  </section>
</Layout>

<style>
  .error-section {
    margin: auto;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 550px;
  }

  .error-image__wrapper {
    width: 100%;
    height: auto;
  }

  .error-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .error-link {
    text-align: center;
  }
</style>
