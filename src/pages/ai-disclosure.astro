---
import Layout from "../layouts/Layout.astro";

import SectionHero from "../components/Section/SectionHero.astro";
import SectionCard from "../components/Section/SectionCard.svelte";
import SectionWrapper from "../components/Section/SectionWrapper.astro";
---

<Layout title="AI Disclosure">
  <SectionWrapper>
    <SectionHero
      title={"AI Disclosure"}
      description={"A brief overview of how AI relates to the content and development of this website."}
      eyebrow={"INFO"}
    />
    <SectionCard title="Development" compactText={false}>
      <p class="section-text">
        I use LLMs mostly <b>to get assistance with Design</b>. I generate some
        frontend components using <b>GPT 5.5</b>, and then I manually review and
        modify them to suit my needs.
      </p>

      <br />

      <h3>Generated components (what I remembered)</h3>
      <ol class="disclosure-list">
        <li><strong>Section hero</strong> (100%)</li>
        <li><strong>Preferences panel</strong> in Header (100%)</li>
        <li>
          <strong>Theme switcher</strong> (1:1 port from my other SvelteKit project
          without server logic)
        </li>
        <li>
          <strong>Mobile menu</strong> in Header (~95%)
        </li>
        <li>
          <strong>Dropdown component</strong> (~100%)
        </li>
        <li>
          <strong>Layout of Guestbook section</strong> on Main page (saved just layout,
          other rewritten from scratch)
        </li>
        <li>
          <strong>Background shapes & lines</strong> in Hero component on main page
          (for beauty)
        </li>
      </ol>

      <br />

      <h3>Completely handwritten</h3>
      <ol class="disclosure-list">
        <li><strong>All backend logic</strong></li>
        <li><strong>Full Admin frontend</strong></li>
        <li><strong>API client logic</strong></li>
        <li><strong>Captcha client logic</strong></li>
        <li><strong>API docs for Voiden</strong></li>
      </ol>
    </SectionCard>
    <SectionCard title="Content" compactText={false}>
      <p class="section-text">
        I partially use LLMs (GPT 5.5, Gemini) and Machine Translation (Yandex
        Translate) to translate and rephrase some small static texts on this
        website.
      </p>
    </SectionCard>
  </SectionWrapper>
</Layout>

<style>
  .section-text {
    color: var(--text-muted);
  }

  .disclosure-list {
    padding: 0 1rem;
    color: var(--text-muted);
  }

  .disclosure-list strong {
    color: var(--text-color);
  }
</style>
