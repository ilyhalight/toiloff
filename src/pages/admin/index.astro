---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import SectionHero from "../../components/Section/SectionHero.astro";
import SectionWrapper from "../../components/Section/SectionWrapper.astro";
import { AUTH_LOGIN_PAGE } from "../../lib/api/auth";
import Stats from "../../components/Stats/Stats.astro";
import SectionCard from "../../components/Section/SectionCard.svelte";
import AdminActions, {
  type Link,
} from "../../components/Admin/AdminActions.svelte";

const user = Astro.locals.user;

if (!user) {
  return Astro.redirect(AUTH_LOGIN_PAGE);
}

const links: Link[] = [
  {
    href: "/admin/guestbook",
    title: "Guestbook",
  },
  {
    href: "/admin/projects",
    title: "Projects",
  },
  {
    href: "/admin/images",
    title: "Images",
  },
  {
    href: "/admin/logout",
    title: "Logout",
  },
];
---

<Layout title="Admin">
  <SectionWrapper>
    <SectionHero
      title={"Dashboard"}
      description={`Welcome back, ${user.username}!`}
      eyebrow={"Admin"}
    />
    <Stats />
    <AdminActions title="Available links" {links} />
  </SectionWrapper>
</Layout>
