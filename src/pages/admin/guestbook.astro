---
export const prerender = false;

import { slide } from "astro:transitions";

import AdminGuestbookPanel from "../../components/Admin/AdminGuestbookPanel.svelte";
import SectionHero from "../../components/Section/SectionHero.astro";
import SectionCard from "../../components/Section/SectionCard.svelte";
import SectionWrapper from "../../components/Section/SectionWrapper.astro";
import Layout from "../../layouts/Layout.astro";
import PageSection from "../../components/PageSection/PageSection.astro";
import SegmentedControl from "../../components/Control/SegmentedControl.svelte";

import { AUTH_LOGIN_PAGE } from "../../lib/api/auth";

const user = Astro.locals.user;

if (!user) {
  return Astro.redirect(AUTH_LOGIN_PAGE);
}
---

<Layout title="Admin guestbook">
  <SectionWrapper>
    <SectionHero
      eyebrow="Admin"
      title="Guestbook"
      description="Review public notes, add a reply, and decide what appears on the site."
    />

    <AdminGuestbookPanel client:load />
  </SectionWrapper>
</Layout>
