---
export const prerender = false;

import AdminActions, {
  type Link,
} from "../../../components/Admin/AdminActions.svelte";
import SectionHero from "../../../components/Section/SectionHero.astro";
import SectionWrapper from "../../../components/Section/SectionWrapper.astro";
import Layout from "../../../layouts/Layout.astro";
import AdminsImagesList from "../../../components/Admin/AdminsImagesList.svelte";

import { AUTH_LOGIN_PAGE } from "../../../lib/api/auth";

const user = Astro.locals.user;

if (!user) {
  return Astro.redirect(AUTH_LOGIN_PAGE);
}

const links: Link[] = [
  {
    title: "Upload image",
    href: "/admin/images/upload",
  },
];
---

<Layout title="Admin projects">
  <SectionWrapper>
    <SectionHero
      eyebrow="Admin"
      title="Projects"
      description="Create and organize your projects!"
    />

    <AdminActions title="Actions" {links} />

    <AdminsImagesList client:load />
  </SectionWrapper>
</Layout>
