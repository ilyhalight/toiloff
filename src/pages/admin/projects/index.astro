---
export const prerender = false;

import AdminActions, {
  type Link,
} from "../../../components/Admin/AdminActions.svelte";
import ProjectList from "../../../components/Projects/ProjectList.svelte";
import SectionHero from "../../../components/Section/SectionHero.astro";
import SectionWrapper from "../../../components/Section/SectionWrapper.astro";
import Layout from "../../../layouts/Layout.astro";
import { BackendAPI } from "../../../lib/api";

import { AUTH_LOGIN_PAGE } from "../../../lib/api/auth";

const user = Astro.locals.user;

if (!user) {
  return Astro.redirect(AUTH_LOGIN_PAGE);
}

const links: Link[] = [
  {
    title: "Create",
    href: "/admin/projects/create",
  },
];

const projectsData = await BackendAPI.projects.getAll().catch(() => ({
  items: [],
  nextCursor: null,
  pageSize: 0,
}));
---

<Layout title="Admin projects">
  <SectionWrapper>
    <SectionHero
      eyebrow="Admin"
      title="Projects"
      description="Create and organize your projects!"
    />

    <AdminActions title="Actions" {links} />

    <ProjectList
      client:load
      isAdmin={true}
      projects={projectsData.items}
      nextCursor={projectsData.nextCursor}
    />
  </SectionWrapper>
</Layout>
