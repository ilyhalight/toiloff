---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import ProjectItem from "../components/Project/ProjectItem.astro";
import PageSection from "../components/PageSection/PageSection.astro";
import Project from "../components/Project/Project.astro";
import Stats from "../components/Stats/Stats.astro";
import Guestbook from "../components/Guestbook/Guestbook.astro";
---

<Layout title="Home">
  <Hero />
  <PageSection
    title="Projects"
    link={{
      href: "hello",
      name: "View all",
    }}
  >
    <Project>
      <ProjectItem />
      <ProjectItem />
      <ProjectItem />
      <ProjectItem />
    </Project>
  </PageSection>
  <PageSection title="Stats">
    <Stats />
  </PageSection>
  <PageSection
    title="Guestbook"
    link={{
      href: "guestbook",
      name: "View all",
    }}
  >
    <Guestbook /></PageSection
  >
</Layout>
