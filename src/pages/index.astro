---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import ProjectItem from "../components/Project/ProjectItem.astro";
import PageSection from "../components/PageSection/PageSection.astro";
import Project from "../components/Project/Project.astro";
import Stats from "../components/Stats/Stats.astro";
import GuestbookContent from "../components/Guestbook/GuestbookContent.astro";
import SectionHero from "../components/Section/SectionHero.astro";
import SectionWrapper from "../components/Section/SectionWrapper.astro";
---

<Layout title="Home">
  <Hero />
  <PageSection
    title="Projects"
    link={{
      href: "hello",
      name: "View all",
    }}
  >
    <Project>
      <ProjectItem />
      <ProjectItem />
      <ProjectItem />
      <ProjectItem />
    </Project>
  </PageSection>
  <PageSection title="Stats">
    <Stats />
  </PageSection>

  <SectionWrapper>
    <SectionHero
      eyebrow={"Public notes"}
      title={"Guestbook"}
      description={"Leave a small message, or just say hi."}
    />
    <GuestbookContent />
  </SectionWrapper>
</Layout>
