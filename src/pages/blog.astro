---
import { Image } from "astro:assets";

import Layout from "../layouts/Layout.astro";
import UnderConstructImage from "../assets/errors/under_construct.jpg";
---

<Layout title="Blog">
  <section class="error-section">
    <div class="error-image__wrapper">
      <Image
        class="error-image"
        src={UnderConstructImage}
        alt="Cat wearing a yellow construction hard hat while sitting on a tree stump"
      />
    </div>
    <h3 class="error-title">Page is under construction!</h3>
    <a href="/" class="error-link button button_outline">Go Home</a>
  </section>
</Layout>

<style>
  .error-section {
    margin: auto;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 550px;
  }

  .error-image__wrapper {
    width: 100%;
    height: auto;
  }

  .error-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0.5rem;
  }

  .error-title {
    text-align: center;
  }

  .error-link {
    text-align: center;
  }
</style>
