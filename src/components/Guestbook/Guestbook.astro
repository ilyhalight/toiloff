---
import type { LiveDataEntry } from "astro";
import GuestMessage from "./GuestMessage.astro";
import GuestZeroMessage from "./GuestZeroMessage.astro";
import GuestbookPlaceholder from "./GuestbookPlaceholder.astro";
import type { GuestbookEntry } from "../../lib/api";

interface Props {
  messages: LiveDataEntry<GuestbookEntry>[];
  visibleCount?: number;
  increment?: number;
}

const { messages, visibleCount = messages.length, increment = 3 } = Astro.props;

const hasMore = messages.length > visibleCount;
---

<div class="guestbook" data-guestbook data-guestbook-increment={increment}>
  <ul class="guestbook-list" data-guestbook-list>
    {
      messages.length ? (
        messages.map((message, index) => (
          <GuestMessage message={message.data} hidden={index >= visibleCount} />
        ))
      ) : (
        <GuestZeroMessage />
      )
    }
  </ul>

  <GuestbookPlaceholder />

  <button
    class="button button_outline guestbook__load-more"
    type="button"
    data-guestbook-load-more
    hidden={!hasMore}
  >
    Load more messages
  </button>
</div>

<script>
  function initGuestbookLists() {
    const roots = Array.from(
      document.querySelectorAll<HTMLElement>("[data-guestbook]"),
    );

    for (const root of roots) {
      if (root.dataset.guestbookReady === "true") {
        continue;
      }

      const list = root.querySelector<HTMLElement>("[data-guestbook-list]");
      const button = root.querySelector<HTMLButtonElement>(
        "[data-guestbook-load-more]",
      );
      const placeholder = root.querySelector<HTMLElement>(
        "[data-guestbook-placeholder]",
      );

      if (!list || !button) {
        continue;
      }

      const increment = Number(root.dataset.guestbookIncrement ?? "3");
      const items = Array.from(
        list.querySelectorAll<HTMLElement>("[data-guestbook-item]"),
      );

      root.dataset.guestbookReady = "true";

      const updateButton = () => {
        button.hidden = items.every((item) => !item.hidden);
      };

      button.addEventListener("click", () => {
        button.disabled = true;

        if (placeholder) {
          placeholder.hidden = false;
        }

        window.setTimeout(() => {
          let revealed = 0;

          for (const item of items) {
            if (!item.hidden || revealed >= increment) {
              continue;
            }

            item.hidden = false;
            revealed += 1;
          }

          if (placeholder) {
            placeholder.hidden = true;
          }

          button.disabled = false;
          updateButton();
        }, 320);
      });

      updateButton();
    }
  }

  document.addEventListener("astro:page-load", initGuestbookLists);
</script>

<style>
  .guestbook {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .guestbook-list {
    display: flex;
    flex-direction: column;
    list-style: none;
    gap: 1rem;
  }

  .guestbook__load-more {
    align-self: center;
  }

  .guestbook__load-more:disabled {
    cursor: wait;
    opacity: 0.7;
  }
</style>
