---
import { guestbookMessages, type GuestbookMessage } from "../../data/guestbook";
import Guestbook from "./Guestbook.astro";
import GuestbookForm from "./GuestbookForm.astro";

interface Props {
  messages?: GuestbookMessage[];
  visibleCount?: number;
  increment?: number;
}

const {
  messages = guestbookMessages,
  visibleCount = 4,
  increment = 3,
} = Astro.props;
---

<div class="guestbook-page__content">
  <aside class="guestbook-page__form" aria-label="Create guestbook message">
    <GuestbookForm />
  </aside>

  <div class="guestbook-page__messages">
    <div class="guestbook-page__messages-head">
      <h2 class="guestbook-page__title">Recent messages</h2>
      <p class="guestbook-page__description">
        All guestbook messages are moderated before they appear here.
      </p>
    </div>

    <Guestbook
      messages={messages}
      visibleCount={visibleCount}
      increment={increment}
    />
  </div>
</div>

<style>
  .guestbook-page__content {
    display: grid;
    grid-template-columns: minmax(18rem, 0.78fr) minmax(0, 1.22fr);
    gap: 1rem;
    align-items: start;
  }

  .guestbook-page__form {
    position: sticky;
    top: 7rem;
  }

  .guestbook-page__messages {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    min-width: 0;
  }

  .guestbook-page__messages-head {
    padding: 1.25rem;
    border-radius: 1.5rem;
    background: var(--surface-bg);
  }

  .guestbook-page__title {
    margin-top: 0.25rem;
    font-size: clamp(1.9rem, 5vw, 3.5rem);
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .guestbook-page__description {
    margin-top: 0.75rem;
    max-width: 38rem;
    color: var(--text-muted);
  }

  @media screen and (max-width: 860px) {
    .guestbook-page__content {
      grid-template-columns: 1fr;
    }

    .guestbook-page__form {
      position: static;
    }
  }
</style>
