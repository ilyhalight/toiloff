<form class="guestbook-form" data-guestbook-form>
  <div class="guestbook-form__head">
    <p class="guestbook-form__eyebrow">Create message</p>
    <h2 class="guestbook-form__title">Write smth</h2>
    <p class="guestbook-form__description">
      This can be anything, within reason
    </p>
  </div>

  <label class="guestbook-form__field" for="guestbook-name">
    <span class="guestbook-form__label">Name</span>
    <input
      class="guestbook-form__control"
      id="guestbook-name"
      name="name"
      type="text"
      autocomplete="name"
      maxlength="80"
      placeholder="Anonymous"
      required
    />
  </label>

  <label class="guestbook-form__field" for="guestbook-message">
    <span class="guestbook-form__label">Message</span>
    <textarea
      class="guestbook-form__control guestbook-form__control_textarea"
      id="guestbook-message"
      name="message"
      maxlength="600"
      placeholder="Say something small and human..."
      required></textarea>
  </label>

  <label class="guestbook-form__field" for="guestbook-link">
    <span class="guestbook-form__label">Link <small>optional</small></span>
    <input
      class="guestbook-form__control"
      id="guestbook-link"
      name="link"
      type="url"
      inputmode="url"
      placeholder="https://example.com"
    />
  </label>

  <label class="guestbook-form__field" for="guestbook-link-label">
    <span class="guestbook-form__label">Link label <small>optional</small></span
    >
    <input
      class="guestbook-form__control"
      id="guestbook-link-label"
      name="linkLabel"
      type="text"
      maxlength="80"
      placeholder="@username"
    />
  </label>

  <p
    class="guestbook-form__status"
    data-guestbook-form-status
    role="status"
    aria-live="polite"
    hidden
  ></p>

  <button class="button guestbook-form__submit" type="submit">
    Send for moderation
  </button>
</form>

<script>
  function initGuestbookForms() {
    const forms = Array.from(
      document.querySelectorAll<HTMLFormElement>("[data-guestbook-form]")
    );

    for (const form of forms) {
      if (form.dataset.guestbookFormReady === "true") {
        continue;
      }

      const status = form.querySelector<HTMLElement>(
        "[data-guestbook-form-status]"
      );
      const submit = form.querySelector<HTMLButtonElement>(
        "button[type='submit']"
      );

      if (!status || !submit) {
        continue;
      }

      form.dataset.guestbookFormReady = "true";

      form.addEventListener("submit", (event) => {
        event.preventDefault();

        if (!form.checkValidity()) {
          form.reportValidity();
          return;
        }

        submit.disabled = true;
        status.hidden = true;

        window.setTimeout(() => {
          form.reset();
          status.textContent =
            "Message queued for moderation. Thanks for signing.";
          status.hidden = false;
          submit.disabled = false;
        }, 360);
      });
    }
  }

  document.addEventListener("astro:page-load", initGuestbookForms);
</script>

<style>
  .guestbook-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.25rem;
    border-radius: 1.5rem;
    background: var(--surface-bg);
  }

  .guestbook-form__head {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .guestbook-form__eyebrow,
  .guestbook-form__label {
    color: var(--text-muted);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .guestbook-form__eyebrow {
    color: var(--primary-color);
    font-size: 0.85rem;
  }

  .guestbook-form__title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    line-height: 1;
  }

  .guestbook-form__description,
  .guestbook-form__label small {
    color: var(--text-muted);
    font-weight: 500;
    text-transform: none;
    letter-spacing: 0;
  }

  .guestbook-form__field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .guestbook-form__control {
    width: 100%;
    padding: 1rem 1.1rem;
    border: 1px solid transparent;
    border-radius: 1rem;
    background: var(--onsurface-bg);
    transition:
      border-color 0.2s ease,
      background-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .guestbook-form__control:hover,
  .guestbook-form__control:focus {
    background: var(--onsurface-hover-bg);
  }

  .guestbook-form__control:focus {
    border-color: var(--stroke-color);
    box-shadow: 0 0 0 0.2rem var(--onsurface-bg);
  }

  .guestbook-form__control_textarea {
    min-height: 9rem;
    resize: vertical;
  }

  .guestbook-form__status {
    padding: 0.9rem 1rem;
    border-radius: 1rem;
    background: color-mix(in srgb, var(--success-color), transparent 84%);
    color: var(--text-color);
  }

  .guestbook-form__submit {
    width: 100%;
  }

  .guestbook-form__submit:disabled {
    cursor: wait;
    opacity: 0.7;
  }
</style>
