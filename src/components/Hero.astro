---
import { fade } from "astro:transitions";
---

<section class="hero" transition:animate="fade">
  <div class="hero-shapes" aria-hidden="true">
    <div class="hero-shape hero-shape--1"></div>
    <div class="hero-shape hero-shape--2"></div>
    <div class="hero-shape hero-shape--3"></div>
    <svg class="hero-lines" viewBox="0 0 1280 800" preserveAspectRatio="none">
      <path
        class="hero-line hero-line--1"
        d="M0 600 Q 320 300 640 500 T 1284 200"></path>
      <path
        class="hero-line hero-line--2"
        d="M0 500 Q 300 700 600 400 T 1280 300"></path>
      <path
        class="hero-line hero-line--3"
        d="M0 700 Q 400 500 800 600 T 1280 100"></path>
    </svg>
  </div>
  <div class="hero-content">
    <h1 class="hero-title">
      Make yourself at home
      <svg
        class="hero-asterisk hero-asterisk--in-title"
        viewBox="0 0 24 24"
        width="36"
        height="36"
      >
        <path
          d="M12 21q-.425 0-.712-.288T11 20v-5.6l-3.95 3.975q-.3.3-.712.3t-.713-.3t-.3-.712t.3-.713L9.6 13H4q-.425 0-.712-.288T3 12t.288-.712T4 11h5.6L5.625 7.05q-.3-.3-.3-.712t.3-.713t.713-.3t.712.3L11 9.6V4q0-.425.288-.712T12 3t.713.288T13 4v5.6l3.95-3.975q.3-.3.713-.3t.712.3t.3.713t-.3.712L14.4 11H20q.425 0 .713.288T21 12t-.288.713T20 13h-5.6l3.975 3.95q.3.3.3.713t-.3.712t-.712.3t-.713-.3L13 14.4V20q0 .425-.288.713T12 21"
          fill="var(--primary-color)"
          opacity="0.5"></path>
      </svg>
    </h1>
    <p class="hero-subtitle">
      A quiet place on the web where I keep my projects and ideas.
    </p>
    <ul class="hero-actions">
      <li class="hero-actions__item">
        <a href="/" class="hero-actions__item-link button">Contact Me</a>
      </li>
      <li class="hero-actions__item">
        <a href="/" class="hero-actions__item-link button button_outline"
          >View CV</a
        >
      </li>
    </ul>
  </div>
</section>

<style>
  .hero {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
    padding: 2rem;
    position: relative;
    min-height: calc(100svh - 100px);
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 720px;
    z-index: 1;
  }

  .hero-title {
    font-size: 4.5rem;
    font-weight: 900;
    color: var(--primary-color);
    position: relative;
    text-wrap: balance;
  }

  .hero-asterisk {
    pointer-events: none;
  }

  .hero-asterisk--in-title {
    position: absolute;
    top: -0.75rem;
    right: 0;
  }

  .hero-shapes {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero-shape {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.12;
  }

  .hero-shape--1 {
    width: 300px;
    height: 300px;
    background: rgb(220, 90, 91);
    top: 5%;
    right: 0;
    border-radius: 60% 40% 50% 30% / 40% 50% 60% 50%;
  }

  .hero-shape--2 {
    width: 250px;
    height: 250px;
    background: rgb(110, 41, 255);
    bottom: 10%;
    left: 5%;
    border-radius: 50% 40% 30% 60% / 60% 30% 50% 40%;
  }

  .hero-shape--3 {
    width: 200px;
    height: 200px;
    background: rgb(255, 174, 0);
    top: 55%;
    left: 10%;
    border-radius: 40% 60% 50% 40% / 50% 40% 60% 50%;
  }

  .hero-lines {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .hero-line {
    fill: none;
    stroke-width: 1;
    opacity: 0.08;
  }

  .hero-line--1 {
    stroke: var(--primary-color);
    stroke-width: 2;
  }

  .hero-line--2 {
    stroke: var(--text-color);
    stroke-width: 1;
  }

  .hero-line--3 {
    stroke: var(--primary-color);
    stroke-width: 0.5;
    stroke-dasharray: 8 6;
  }

  .hero-subtitle {
    font-size: 2.75rem;
  }

  .hero-actions {
    list-style: none;
    display: flex;
    gap: 1.5rem;
    padding: 2rem 0;
  }

  .hero-actions__item {
    display: flex;
    user-select: none;
  }

  @media screen and (max-width: 768px) {
    .hero {
      padding: 1.5rem;
      min-height: calc(100svh - 80px);
    }

    .hero-shape {
      opacity: 0.2;
    }

    .hero-shape--1 {
      width: 200px;
      height: 200px;
    }

    .hero-shape--2 {
      width: 160px;
      height: 160px;
    }

    .hero-shape--3 {
      display: none;
    }

    .hero-lines {
      display: none;
    }
  }

  @media screen and (max-width: 450px) {
    .hero-actions__item-link.button {
      font-size: 1rem;
    }
  }

  @media screen and (max-width: 375px) {
    .hero-actions {
      flex-direction: column;
      gap: 1rem;
    }

    .hero-actions__item-link {
      width: 100%;
    }
  }
</style>
