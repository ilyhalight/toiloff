<section class="hero">
  <div class="hero-content">
    <h1 class="hero-title">
      Make yourself at home
      <svg
        class="hero-asterisk hero-asterisk--in-title"
        viewBox="0 0 24 24"
        width="36"
        height="36"
      >
        <path
          d="M12 21q-.425 0-.712-.288T11 20v-5.6l-3.95 3.975q-.3.3-.712.3t-.713-.3t-.3-.712t.3-.713L9.6 13H4q-.425 0-.712-.288T3 12t.288-.712T4 11h5.6L5.625 7.05q-.3-.3-.3-.712t.3-.713t.713-.3t.712.3L11 9.6V4q0-.425.288-.712T12 3t.713.288T13 4v5.6l3.95-3.975q.3-.3.713-.3t.712.3t.3.713t-.3.712L14.4 11H20q.425 0 .713.288T21 12t-.288.713T20 13h-5.6l3.975 3.95q.3.3.3.713t-.3.712t-.712.3t-.713-.3L13 14.4V20q0 .425-.288.713T12 21"
          fill="var(--primary-color)"
          opacity="0.5"></path>
      </svg>
    </h1>
    <p class="hero-subtitle">
      A quiet place on the web where I keep my projects and ideas.
    </p>
    <ul class="hero-actions">
      <li class="hero-actions__item">
        <a href="/" class="hero-actions__item-link button">Contact Me</a>
      </li>
      <li class="hero-actions__item">
        <a href="/" class="hero-actions__item-link button button_outline"
          >View CV</a
        >
      </li>
    </ul>
  </div>
</section>

<style>
  .hero {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
    padding: 2rem;
    position: relative;
    overflow: hidden;
    min-height: calc(100svh - 100px);
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 720px;
    z-index: 1;
  }

  .hero-title {
    font-size: 4.5rem;
    font-weight: 900;
    color: var(--primary-color);
    position: relative;
    text-wrap: balance;
  }

  .hero-asterisk {
    pointer-events: none;
  }

  .hero-asterisk--in-title {
    position: absolute;
    top: -0.75rem;
    right: 0;
  }

  .hero-subtitle {
    font-size: 2.75rem;
  }

  .hero-actions {
    list-style: none;
    display: flex;
    gap: 1.5rem;
    padding: 2rem 0;
  }

  .hero-actions__item {
    display: flex;
  }

  @media screen and (max-width: 768px) {
    .hero {
      padding: 1.5rem;
      min-height: calc(100svh - 80px);
    }
  }

  @media screen and (max-width: 450px) {
    .hero-actions__item-link.button {
      font-size: 1rem;
    }
  }

  @media screen and (max-width: 375px) {
    .hero-actions {
      flex-direction: column;
      gap: 1rem;
    }

    .hero-actions__item-link {
      width: 100%;
    }
  }
</style>
