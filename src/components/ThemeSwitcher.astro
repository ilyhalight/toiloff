          <stop stop-color="#f89f22"></stop>
          <stop offset="1" stop-color="#fbdf40"></stop>
        </linearGradient>
      </defs>
    </g>
  </svg>
</button>

<script>
  function initThemeSwitchers() {
    const themeButtons = document.querySelectorAll<HTMLElement>(
      "[data-theme-switcher]"
    );

    for (const themeBtn of themeButtons) {
      if (themeBtn.dataset.themeSwitcherBound === "true") {
        continue;
      }

      themeBtn.dataset.themeSwitcherBound = "true";
      themeBtn.addEventListener("click", (e) => {
        e.preventDefault();
        const nextTheme =
          document.body.dataset.theme === "light" ? "dark" : "light";

        document.body.dataset.theme = nextTheme;
      });
    }
  }

  document.addEventListener("astro:page-load", initThemeSwitchers);
</script>

<style>
  .theme-switcher {
    --tc-background: #0b0a19;
    --tc-small-shadow: #232230;
    --tc-medium-shadow: #3c3b47;
    --tc-big-shadow: #52515c;
    --tc-holl-shadow: #b6bdc3;
    --tc-holl-background: #bdc3c9;
    --tc-pointer-below: #bcc5ce;
    --tc-pointer-upper: #e2e7ed;
    --tc-pointer-main: #d1d8e0;
    --tc-stars: #fff;
    display: flex;
    padding: 0;
    color: inherit;
    background: transparent;
    cursor: pointer;
    line-height: 0;
  }

  :global([data-theme="light"]) .theme-switcher {
    --tc-background: #5ca6ff;
    --tc-small-shadow: #6cafff;
    --tc-medium-shadow: #7db8ff;
    --tc-big-shadow: #8dc1ff;
    --tc-pointer-below: #faa633;
    --tc-pointer-upper: var(--tc-pointer-light);
  }

  .theme-switcher__background {
    fill: var(--tc-background);
  }

  .theme-switcher__stroke {
    stroke: var(--tc-background);
  }

  .theme-switcher__stars {
    fill: var(--tc-stars);
    opacity: 1;
    transform-origin: center;
    transition:
      opacity 0.3s ease,
      transform 0.3s ease;
  }

  :global([data-theme="light"]) .theme-switcher__stars {
    opacity: 0;
    transform: scale(0.85);
  }

  .theme-switcher__clouds {
    opacity: 0;
    transform: translateX(594px);
    transition:
      opacity 0.5s ease,
      transform 0.5s ease;
  }

  :global([data-theme="light"]) .theme-switcher__clouds {
    opacity: 1;
    transform: translateX(0);
  }

  .theme-switcher__shadow {
    transition: transform 0.5s ease;
  }

  .theme-switcher__shadow_small {
    fill: var(--tc-small-shadow);
  }

  .theme-switcher__shadow_medium {
    fill: var(--tc-medium-shadow);
  }

  .theme-switcher__shadow_big {
    fill: var(--tc-big-shadow);
  }

  :global([data-theme="light"]) .theme-switcher__shadow_small {
    transform: translateX(-271px);
  }

  :global([data-theme="light"]) .theme-switcher__shadow_medium {
    transform: translateX(-440px);
  }

  :global([data-theme="light"]) .theme-switcher__shadow_big {
    transform: translateX(-594px);
  }

  .theme-switcher__pointer {
    transition: transform 0.5s ease;
  }

  :global([data-theme="light"]) .theme-switcher__pointer {
    transform: translateX(-404px);
  }

  .theme-switcher__pointer-obj ellipse {
    transition:
      fill 0.5s ease,
      opacity 0.2s ease;
  }

  .theme-switcher__pointer-obj ellipse:nth-child(1) {
    fill: var(--tc-pointer-below);
  }

  .theme-switcher__pointer-obj ellipse:nth-child(2) {
    fill: var(--tc-pointer-upper);
  }

  .theme-switcher__moon-fill {
    fill: var(--tc-pointer-main);
  }

  :global([data-theme="light"]) .theme-switcher__moon-fill {
    opacity: 0;
  }

  .theme-switcher__pointer-hollows {
    opacity: 1;
    transition: opacity 0.2s ease;
  }

  :global([data-theme="light"]) .theme-switcher__pointer-hollows {
    opacity: 0;
  }

  .theme-switcher__pointer-hollows circle {
    fill: var(--tc-holl-shadow);
  }

  .theme-switcher__pointer-hollows ellipse {
    fill: var(--tc-holl-background);
  }

  @media (prefers-reduced-motion: reduce) {
    .theme-switcher__stars,
    .theme-switcher__clouds,
    .theme-switcher__shadow,
    .theme-switcher__pointer,
    .theme-switcher__pointer-obj ellipse,
    .theme-switcher__pointer-hollows {
      transition: none;
    }
  }
</style>
