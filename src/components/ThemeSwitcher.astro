          fill="#add2ff"></path>
      </g>
      <g class="theme-switcher__pointer">
        <g class="theme-switcher__pointer-obj">
          <ellipse cx="523" cy="119" rx="100" ry="98"></ellipse>
          <ellipse cx="523" cy="115" rx="100" ry="98"></ellipse>
          <ellipse
            class="theme-switcher__moon-fill"
            cx="523"
