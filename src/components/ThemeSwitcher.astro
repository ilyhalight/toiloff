---
interface Props {
  id?: string;
}

const { id = "default" } = Astro.props;
const safeId = id.replace(/[^a-z0-9_-]/gi, "-");
const maskId = `theme-switcher-mask-${safeId}`;
const gradientId = `theme-switcher-gradient-${safeId}`;
---

<button
  class="theme-switcher"
  type="button"
  aria-label="Switch theme"
  data-theme-switcher
  style={`--tc-pointer-light: url(#${gradientId});`}
