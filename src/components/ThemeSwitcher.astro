      x="1.5"
      y="1.5"
      width="641"
      height="231"
      rx="115.5"
      stroke-opacity="0.25"
      stroke-width="3"></rect>
    <mask
      id={maskId}
      style="mask-type: alpha"
      maskUnits="userSpaceOnUse"
      x="3"
      y="3"
      width="638"
      height="228"
    >
      <rect x="3" y="3" width="638" height="228" rx="114" fill="#52515c"></rect>
    </mask>
    <g mask={`url(#${maskId})`}>
      <g class="theme-switcher__shadows">
