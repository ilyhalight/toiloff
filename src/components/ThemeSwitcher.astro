          <circle cx="486" cy="79" r="24"></circle>
          <ellipse cx="486" cy="79.5" rx="24" ry="23.5"></ellipse>
          <circle cx="591" cy="123" r="14"></circle>
          <ellipse cx="591" cy="123.5" rx="14" ry="13.5"></ellipse>
          <circle cx="547" cy="181" r="11"></circle>
          <ellipse cx="547" cy="181.5" rx="11" ry="10.5"></ellipse>
        </g>
      </g>
      <defs>
        <linearGradient
          id={gradientId}
          x1="121"
          y1="17"
          x2="121"
          y2="213"
          gradientUnits="userSpaceOnUse"
