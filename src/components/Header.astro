---
import Logo from "./Logo.astro";
---

<header class="header-container">
  <div class="header-content">
    <a class="logo" href="/">
      <span class="logo-img">
        <Logo />
      </span>
      <span class="logo-text">Toiloff</span>
    </a>
    <nav class="header-nav">
      <ul class="nav-list">
        <li class="nav-list__item">
          <a class="nav-list__item-link" href="/">Blog</a>
        </li>
        <li class="nav-list__item">
          <a class="nav-list__item-link" href="/">About</a>
        </li>
        <li class="nav-list__item">
          <a class="nav-list__item-link" href="/">Donate</a>
        </li>
        <li class="nav-list__item">
          <a class="nav-list__item-link" href="/">Tools</a>
        </li>
        <li class="nav-list__item">
          <a class="nav-list__item-link" href="/" id="theme-changer"
            >Theme tester :></a
          >
        </li>
      </ul>
      <span class="nav-menu"
        ><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
          ><!-- Icon from Stash Icons by Pingback LLC - https://github.com/stash-ui/icons/blob/master/LICENSE -->
          <path
            fill="currentColor"
            d="M4 6a1 1 0 0 1 1-1h14a1 1 0 1 1 0 2H5a1 1 0 0 1-1-1m0 6a1 1 0 0 1 1-1h14a1 1 0 1 1 0 2H5a1 1 0 0 1-1-1m1 5a1 1 0 1 0 0 2h14a1 1 0 1 0 0-2z"
          ></path></svg
        ></span
      >
    </nav>
  </div>
</header>

<script>
  const themeBtn = document.getElementById("theme-changer");
  themeBtn?.addEventListener("click", (e) => {
    e.preventDefault();
    const nextTheme =
      document.body.dataset.theme === "light" ? "dark" : "light";
    document.body.dataset.theme = nextTheme;
  });
</script>

<style>
  .header-container {
    padding: 0.5rem 1.5rem 0;
    height: 100px;
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
  }

  .header-content {
    position: fixed;
    z-index: 1337;
    display: flex;
    align-items: center;
    padding: 1rem 1.25rem;
    backdrop-filter: blur(64px);
    background-color: var(--header-bg);
    border-radius: 1.75rem;
    width: min-content;
    gap: 4rem;
  }

  .logo {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.25rem;
    color: var(--logo-color);
    transition: color ease 0.25s;
  }

  .logo:hover {
    color: var(--primary-color);
  }

  .logo-img {
    width: 1.5rem;
    height: 1.5rem;
  }

  .logo-text {
    font-size: 1.5rem;
    font-weight: bold;
  }

  .nav-list {
    list-style: none;
    display: flex;
    gap: 1.5rem;
  }

  .nav-menu {
    display: none;
  }

  @media screen and (max-width: 500px) {
    .header-content {
      width: calc(100% - 0.5rem);
      justify-content: space-between;
    }

    .nav-list {
      display: none;
    }

    .nav-menu {
      display: flex;
      cursor: pointer;
      width: 2.25rem;
    }
  }

  .nav-list__item {
    font-weight: bold;
    text-wrap: nowrap;
    letter-spacing: 0.2px;
    color: var(--header-link-color);
    transition: color ease 0.25s;
  }

  .nav-list__item:hover {
    color: var(--header-link-hover-color);
  }
</style>
