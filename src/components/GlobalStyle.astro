<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    --background: #05010d;
    --surface-bg: #131317;
    --onsurface-bg: #27272a;
    --onsurface-hover-bg: #1d1d1d;
    --text-color: rgb(220, 220, 230);
    --text-muted: rgb(130, 130, 150);
    --text-hover-color: #fff;
    --primary-color: #ff6363;
    --warning-color: #facc15;
    /* --primary-surface-bg: #ff636321; */
    --primary-surface-bg: color-mix(
      in srgb,
      var(--primary-color),
      transparent 84%
    );
    --success-color: #4ade80;
    --logo-color: #fff;
    --stroke-color: #3a3a3f;
    --overlay-shadow: 0 1rem 3rem rgba(0, 0, 0, 0.26);

    --header-bg: #1a1a1aa3;
    --header-link-color: var(--text-color);
    --header-link-hover-color: var(--text-hover-color);

    --button-bg: #e6e6e6;
    --button-shadow-color: var(--text-color);
    --button-hover-color: var(--text-hover-color);
    --button-text-color: var(--background);
    --button_outline-border-color: var(--stroke-color);
    --button_outline-bg: #28292e;
  }

  [data-theme="light"] {
    --background: #fff;
    --surface-bg: #f5f5f5;
    --onsurface-bg: #eaeaea;
    --onsurface-hover-bg: #dddddd;
    --text-color: #0a0a0f;
    --text-muted: #616171;
    --text-hover-color: #302f2f;
    --logo-color: #0a0a0f;
    --stroke-color: #c0c0c0;

    --header-bg: #edededa3;
    --header-link-color: var(--text-color);
    --header-link-hover-color: var(--text-muted);

    --button-bg: #05010d;
    --button-shadow-color: var(--text-color);
    --button-hover-color: var(--text-hover-color);
    --button-text-color: var(--background);
    --button_outline-border-color: var(--stroke-color);
    --button_outline-bg: #f0f0f0;
  }

  body {
    background: var(--background);
    color: var(--text-color);
    font-family: var(--font-poppins), "Inter", system-ui, sans-serif;
    font-size: 16px;
    scrollbar-color: rgba(255, 255, 255, 0.1) #252525;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  input,
  textarea,
  button {
    font-size: inherit;
    font-family: inherit;
    border: none;
    outline: none;
    color: inherit;
  }

  .button {
    font-size: 1.25rem;
    font-weight: 500;
    cursor: pointer;
    padding: 1rem 2rem;
    border-radius: 1rem;
    outline: 2px solid var(--button-outline-color);
    background: var(--button-bg);
    color: var(--button-text-color);
    transition: background-color 0.25s ease;
  }

  .button:not(:disabled):focus {
    box-shadow: 0 0 0 0.25rem var(--button-shadow-color);
  }

  .button:not(:disabled):hover {
    background: var(--button-hover-color);
  }

  .button:disabled {
    cursor: wait;
    opacity: 0.7;
  }

  .button.button_outline {
    color: var(--text-color);
    border: 1px solid var(--button_outline-border-color);
    background: transparent;
  }

  .button.button_outline:hover {
    background: var(--button_outline-bg);
  }

  .text-truncate {
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }

  .text-wrap {
    overflow-wrap: break-word;
    white-space: pre-wrap;
  }

  .link {
    font-weight: 600;
    text-decoration: none;
    color: var(--text-muted);
    transition: color 0.25s ease;
  }

  .link:hover {
    color: var(--text-color);
  }
</style>
