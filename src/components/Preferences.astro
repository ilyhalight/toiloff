---
interface Props {
  title?: string;
}

const { title = "Preferences" } = Astro.props;
---

<details class="preferences" data-preferences>
  <summary class="preferences__trigger" aria-label="Open preferences">
    <svg
      aria-hidden="true"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
    >
      <path
        fill="currentColor"
        d="M19.43 12.98c.04-.32.07-.65.07-.98s-.02-.66-.07-.98l2.11-1.65a.5.5 0 0 0 .12-.64l-2-3.46a.5.5 0 0 0-.61-.22l-2.49 1a7.28 7.28 0 0 0-1.69-.98L14.5 2.42A.5.5 0 0 0 14 2h-4a.5.5 0 0 0-.5.42L9.13 5.07c-.61.24-1.18.57-1.69.98l-2.49-1a.5.5 0 0 0-.61.22l-2 3.46a.5.5 0 0 0 .12.64l2.11 1.65c-.04.32-.08.65-.08.98s.03.66.08.98l-2.11 1.65a.5.5 0 0 0-.12.64l2 3.46c.14.24.42.34.67.22l2.43-1a7.28 7.28 0 0 0 1.69.98l.37 2.65c.04.24.25.42.5.42h4c.25 0 .46-.18.5-.42l.37-2.65c.61-.24 1.18-.57 1.69-.98l2.43 1c.25.12.53.02.67-.22l2-3.46a.5.5 0 0 0-.12-.64l-2.11-1.65ZM12 15.5A3.5 3.5 0 1 1 12 8a3.5 3.5 0 0 1 0 7Z"
      ></path>
    </svg>
  </summary>
  <div class="preferences__panel">
    <span class="preferences__title">{title}</span>
    <slot />
  </div>
</details>

<script>
  function initPreferences() {
    if (
      document.documentElement.dataset.preferencesOutsideClickBound === "true"
    ) {
      return;
    }

    document.documentElement.dataset.preferencesOutsideClickBound = "true";

    document.addEventListener("click", (e) => {
      const target = e.target;

      if (!(target instanceof Node)) {
        return;
      }

      if (target.parentElement?.closest("[data-preferences]")) {
        return;
      }

      const preferencesList =
        document.querySelectorAll<HTMLDetailsElement>("[data-preferences]");
      for (const preferences of preferencesList) {
        preferences.open = false;
      }
    });
  }

  initPreferences();
  document.addEventListener("astro:page-load", initPreferences);
</script>

<style>
  .preferences {
    position: relative;
  }

  .preferences__trigger {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 999px;
    color: var(--header-link-color);
    background: transparent;
    cursor: pointer;
    list-style: none;
    transition:
      color 0.2s ease,
      background-color 0.2s ease,
      transform 0.2s ease;
  }

  .preferences__trigger::-webkit-details-marker {
    display: none;
  }

  .preferences__trigger:hover {
    color: var(--header-link-hover-color);
    background: var(--onsurface-bg);
  }

  .preferences[open] .preferences__trigger {
    color: var(--primary-color);
    background: var(--onsurface-bg);
    transform: rotate(30deg);
  }

  .preferences__trigger svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  .preferences__panel {
    position: absolute;
    top: calc(100% + 1rem);
    right: 0;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-width: 22rem;
    padding: 0.75rem;
    border: 1px solid var(--stroke-color);
    border-radius: 1.25rem;
    background: var(--header-bg);
    box-shadow: var(--overlay-shadow);
    backdrop-filter: blur(48px);
  }

  .preferences__panel::before {
    content: "";
    position: absolute;
    top: -0.35rem;
    right: 1rem;
    width: 0.7rem;
    height: 0.7rem;
    border-top: 1px solid var(--stroke-color);
    border-left: 1px solid var(--stroke-color);
    background: var(--header-bg);
    transform: rotate(45deg);
  }

  .preferences__title {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--text-muted);
  }
</style>
