---
interface Props {
  accent: string;
  ariaLabel: string;
  eyebrow: string;
  title: string;
  subtitle?: string;
}

const { accent, ariaLabel, eyebrow, title, subtitle } = Astro.props;
---

<div
  class="stats-content-card"
  aria-label={ariaLabel}
  style={`--stats-content-color: ${accent};`}
>
  <div class="stats-content-card__hero">
    <span class="stats-content-card__mark" aria-hidden="true">
      <slot name="icon" />
    </span>
    <div class="stats-content-card__hero-copy">
      <span class="stats-content-card__eyebrow">{eyebrow}</span>
      <h4>{title}</h4>
      {subtitle && <span class="stats-content-card__subtitle">{subtitle}</span>}
    </div>
  </div>
  <div class="stats-content-card__details">
    <slot />
  </div>
</div>

<style>
  .stats-content-card {
    --stats-content-color: var(--primary-color);
    display: grid;
    gap: 0.75rem;
    margin-top: 0.25rem;
  }

  .stats-content-card__hero {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.85rem;
    min-height: 7rem;
    padding: 1rem;
    border: 1px solid
      color-mix(in srgb, var(--stats-content-color) 34%, transparent);
    border-radius: 1rem;
    background:
      radial-gradient(
        circle at 14% 18%,
        color-mix(in srgb, var(--stats-content-color) 24%, transparent),
        transparent 38%
      ),
      linear-gradient(
        135deg,
        color-mix(in srgb, var(--stats-content-color) 12%, transparent),
        transparent 54%
      ),
      color-mix(in srgb, var(--onsurface-bg) 72%, transparent);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      0 0.75rem 2rem
        color-mix(in srgb, var(--stats-content-color) 10%, transparent);
  }

  .stats-content-card__hero::after {
    content: "";
    position: absolute;
    right: 1rem;
    bottom: 1rem;
    width: 4rem;
    height: 4rem;
    border: 1px solid
      color-mix(in srgb, var(--stats-content-color) 18%, transparent);
    border-radius: 999px;
    opacity: 0.65;
    pointer-events: none;
  }

  .stats-content-card__mark {
    display: grid;
    flex: 0 0 auto;
    width: 3.75rem;
    height: 3.75rem;
    place-items: center;
    border-radius: 1rem;
    color: var(--stats-content-color);
    filter: drop-shadow(
      0 0.5rem 1rem
        color-mix(in srgb, var(--stats-content-color) 32%, transparent)
    );
  }

  :global(.stats-content-card__mark > svg) {
    width: 2.1rem;
    height: 2.1rem;
  }

  .stats-content-card__hero-copy {
    min-width: 0;
  }

  .stats-content-card__eyebrow {
    display: block;
    margin-bottom: 0.25rem;
    color: color-mix(
      in srgb,
      var(--stats-content-color) 74%,
      var(--text-color)
    );
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .stats-content-card__hero h4 {
    color: var(--stats-content-color);
    font-size: 2rem;
    line-height: 1;
    letter-spacing: -0.05em;
  }

  .stats-content-card__subtitle {
    display: block;
    margin-top: 0.25rem;
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  .stats-content-card__details {
    display: grid;
    gap: 0.5rem;
  }
</style>
