---
interface Props {
  line1: string
  line2: string
  line3: string
}

const { line1, line2, line3 } = Astro.props
---

<div class="stats-item__lines" aria-hidden="true">
  <svg viewBox="0 0 400 300" preserveAspectRatio="none">
    <path class="stats-line stats-line--1" d={line1}></path>
    <path class="stats-line stats-line--2" d={line2}></path>
    <path class="stats-line stats-line--3" d={line3}></path>
  </svg>
</div>

<style>
  .stats-item__lines {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: visible;
  }

  .stats-item__lines svg {
    width: 100%;
    height: 100%;
  }

  .stats-line {
    fill: none;
    opacity: 0.12;
  }

  .stats-line--1 {
    stroke: var(--line-color, var(--primary-color));
    stroke-width: 2;
  }

  .stats-line--2 {
    stroke: var(--text-color);
    stroke-width: 1;
  }

  .stats-line--3 {
    stroke: var(--line-color, var(--primary-color));
    stroke-width: 0.5;
    stroke-dasharray: 6 5;
  }
</style>
