---
import type { BlogPost } from "./types";

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
const dateFormatter = new Intl.DateTimeFormat("en", {
  month: "short",
  day: "numeric",
  year: "numeric",
});
const createdDate = dateFormatter.format(new Date(post.createdAt));
const searchText = [
  post.title,
  post.tag,
  post.createdAt,
  createdDate,
  post.readingTime,
  post.description,
]
  .join(" ")
  .toLowerCase();
---

<li
  class="blog-post"
  data-tag={post.tag.toLowerCase()}
  data-search-text={searchText}
>
  <a class="blog-post__image-link" href={post.href} aria-label={post.title}>
    <img class="blog-post__image" src={post.image} alt="" loading="lazy" />
  </a>
  <div class="blog-post__content">
    <span class="blog-post__tag">{post.tag}</span>
    <a class="blog-post__title-link" href={post.href}>
      <h3 class="blog-post__title">{post.title}</h3>
    </a>
    <p class="blog-post__description text-wrap">{post.description}</p>
    <div class="blog-post__meta">
      <time datetime={post.createdAt}>{createdDate}</time>
      <span>{post.readingTime}</span>
    </div>
  </div>
</li>

<style>
  .blog-post {
    overflow: hidden;
    display: flex;
    flex-direction: column;
    border-radius: 1.25rem;
    background: var(--surface-bg);
  }

  .blog-post[hidden] {
    display: none;
  }

  .blog-post__image-link {
    overflow: hidden;
    display: block;
    margin: 1rem 1rem 0;
    aspect-ratio: 16 / 9;
    border-radius: 0.85rem;
    background: var(--onsurface-bg);
  }

  .blog-post__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .blog-post:hover .blog-post__image {
    transform: scale(1.035);
  }

  .blog-post__content {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 0.65rem;
    padding: 1rem 1.25rem 1.25rem;
  }

  .blog-post__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    color: var(--text-muted);
    font-size: 0.9rem;
    font-weight: 500;
  }

  .blog-post__tag {
    color: var(--text-muted);
    font-size: 0.9rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .blog-post__title-link {
    transition: color 0.25s ease;
  }

  .blog-post__title-link:hover {
    color: var(--primary-color);
  }

  .blog-post__title {
    font-size: clamp(1.35rem, 3vw, 2rem);
    line-height: 1.1;
  }

  .blog-post__description {
    flex: 1;
    color: var(--text-muted);
  }
</style>
