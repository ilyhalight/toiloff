---
import type { BlogPostAuthor } from "./types";

interface Props {
  author: BlogPostAuthor;
}

const { author } = Astro.props;

const AuthorTag = author.href ? "a" : "div";
const authorAttrs = author.href ? { href: author.href } : {};
---

<AuthorTag class="blog-post-author" {...authorAttrs}>
  <img class="blog-post-author__avatar" src={author.avatar} alt="" loading="lazy" />
  <span class="blog-post-author__info">
    <strong class="blog-post-author__name">{author.name}</strong>
    <span class="blog-post-author__role">{author.role}</span>
  </span>
</AuthorTag>

<style>
  .blog-post-author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem;
    border-radius: 1rem;
    background: var(--onsurface-bg);
  }

  .blog-post-author__avatar {
    width: 3rem;
    height: 3rem;
    flex: 0 0 auto;
    border-radius: 999px;
    object-fit: cover;
  }

  .blog-post-author__info {
    display: flex;
    min-width: 0;
    flex-direction: column;
  }

  .blog-post-author__name {
    color: var(--text-color);
  }

  .blog-post-author__role {
    color: var(--text-muted);
    font-size: 0.9rem;
  }
</style>
