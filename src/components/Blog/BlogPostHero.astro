---
import type { BlogPostDetail } from "./types";

interface Props {
  post: BlogPostDetail;
}

const { post } = Astro.props;
const createdDate = new Intl.DateTimeFormat("en", {
  month: "short",
  day: "numeric",
  year: "numeric",
}).format(new Date(post.createdAt));
---

<header class="blog-post-hero" style={`--hero-image: url('${post.heroImage}')`}>
  <div class="blog-post-hero__content">
    <span class="blog-post-hero__tag">{post.tag}</span>
    <h1 class="blog-post-hero__title">{post.title}</h1>
    <p class="blog-post-hero__description">{post.description}</p>
    <div class="blog-post-hero__meta">
      <time datetime={post.createdAt}>{createdDate}</time>
      <span>{post.readingTime}</span>
    </div>
  </div>
</header>

<style>
  .blog-post-hero {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: end;
    min-height: clamp(32rem, 70svh, 46rem);
    padding: clamp(1.5rem, 5vw, 3rem);
    border-radius: 1.5rem;
    background:
      linear-gradient(90deg, rgba(5, 1, 13, 0.92), rgba(5, 1, 13, 0.62) 42%, rgba(5, 1, 13, 0.3)),
      linear-gradient(0deg, rgba(5, 1, 13, 0.78), transparent 58%),
      var(--hero-image) center / cover;
  }

  .blog-post-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(90deg, transparent 0 5rem, rgba(255, 255, 255, 0.08) 5rem 5.05rem);
    opacity: 0.45;
    pointer-events: none;
  }

  .blog-post-hero__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
    max-width: 760px;
  }

  .blog-post-hero__tag {
    color: rgb(190, 190, 205);
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .blog-post-hero__title {
    color: #fff;
    font-size: clamp(3rem, 8vw, 6.5rem);
    line-height: 0.95;
    letter-spacing: -0.07em;
  }

  .blog-post-hero__description {
    max-width: 620px;
    color: rgb(220, 220, 230);
    font-size: clamp(1rem, 2vw, 1.25rem);
  }

  .blog-post-hero__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    color: rgb(180, 180, 195);
    font-weight: 600;
  }

  @media screen and (max-width: 760px) {
    .blog-post-hero {
      min-height: 34rem;
      background:
        linear-gradient(0deg, rgba(5, 1, 13, 0.92), rgba(5, 1, 13, 0.52)),
        var(--hero-image) center / cover;
    }
  }
</style>
