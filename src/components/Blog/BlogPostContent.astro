---
import type { BlogPostContentSection } from "./types";

interface Props {
  sections: BlogPostContentSection[];
}

const { sections } = Astro.props;
---

<article class="blog-post-content">
  {
    sections.map((section) => (
      <section class="blog-post-content__section" id={section.id}>
        <h2 class="blog-post-content__title">{section.title}</h2>
        {section.body.map((paragraph) => (
          <p class="blog-post-content__paragraph">{paragraph}</p>
        ))}
      </section>
    ))
  }
</article>

<style>
  .blog-post-content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    min-width: 0;
    padding: 1.5rem;
    border-radius: 1.5rem;
    background: var(--surface-bg);
  }

  .blog-post-content__section {
    scroll-margin-top: 7rem;
  }

  .blog-post-content__title {
    margin-bottom: 0.75rem;
    font-size: clamp(1.75rem, 4vw, 3rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
  }

  .blog-post-content__paragraph {
    max-width: 72ch;
    color: var(--text-muted);
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .blog-post-content__paragraph + .blog-post-content__paragraph {
    margin-top: 0.9rem;
  }
</style>
