---
import BlogPostAuthorCard from "./BlogPostAuthorCard.astro";
import type { BlogPostAuthor, BlogPostContentSection } from "./types";

interface Props {
  authors: BlogPostAuthor[];
  sections: BlogPostContentSection[];
}

const { authors, sections } = Astro.props;
---

<aside class="blog-post-sidebar" aria-label="Post details">
  <section class="blog-post-sidebar__block">
    <h2 class="blog-post-sidebar__title">Created by</h2>
    <ul class="blog-post-sidebar__authors">
      {
        authors.map((author) => (
          <li class="blog-post-sidebar__author">
            <BlogPostAuthorCard author={author} />
          </li>
        ))
      }
    </ul>
  </section>

  <nav class="blog-post-sidebar__block" aria-label="Post content">
    <h2 class="blog-post-sidebar__title">Content</h2>
    <ol class="blog-post-sidebar__links">
      {
        sections.map((section) => (
          <li>
            <a class="blog-post-sidebar__link" href={`#${section.id}`}>
              {section.title}
            </a>
          </li>
        ))
      }
    </ol>
  </nav>
</aside>

<style>
  .blog-post-sidebar {
    position: sticky;
    top: 7rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-self: start;
    min-width: 0;
  }

  .blog-post-sidebar__block {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1rem;
    border-radius: 1.25rem;
    background: var(--surface-bg);
  }

  .blog-post-sidebar__title {
    color: var(--text-muted);
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .blog-post-sidebar__authors,
  .blog-post-sidebar__links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .blog-post-sidebar__authors,
  .blog-post-sidebar__links {
    list-style: none;
  }

  .blog-post-sidebar__link {
    display: block;
    padding: 0.65rem 0.75rem;
    border-radius: 0.75rem;
    color: var(--text-muted);
    transition:
      background-color 0.2s ease,
      color 0.2s ease;
  }

  .blog-post-sidebar__link:hover {
    background: var(--onsurface-bg);
    color: var(--text-color);
  }

  @media screen and (max-width: 820px) {
    .blog-post-sidebar {
      position: static;
    }
  }
</style>
